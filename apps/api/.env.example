# ================================================================
# TradeAgent — API Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is in .gitignore.
# ================================================================

# ■■ Hedera Network ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Get a free testnet account at: portal.hedera.com
# IMPORTANT: Use ECDSA key type (required for EVM/JSON-RPC)

HEDERA_NETWORK=testnet

OPERATOR_ACCOUNT_ID=0.0.XXXXX
OPERATOR_PRIVATE_KEY=302e020100...   # ECDSA hex private key
OPERATOR_PUBLIC_KEY=302d300706...   # ECDSA hex public key

# ■■ Contracts (filled AFTER Phase 2 deployment) ■■■■■■■■■■■■■
# These will be empty until you run: npm run deploy:native

AGENT_REGISTRY_CONTRACT_ID=        # Hedera contract ID (0.0.XXXXX)
AGENT_REGISTRY_EVM_ADDRESS=        # EVM address (0x...)
STRATEGY_TOKEN_ID=                 # HTS NFT collection ID
AGENT_CONFIG_FILE_ID=              # HFS file store ID (optional)

# ■■ Gemini AI — FREE TIER ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Get free key at: aistudio.google.com
# Free tier: 15 RPM / 1M tokens per day — more than enough

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ■■ Supabase ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Free tier at: supabase.com
# Includes PostgreSQL, Auth, and storage

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct database URL for Prisma
DATABASE_URL=postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ■■ Redis / BullMQ ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Use Redis Cloud free tier: redis.io/try-free
# Or run locally with Docker: docker run -p 6379:6379 redis:alpine

REDIS_URL=redis://localhost:6379

# ■■ NFT Storage (IPFS) ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Free IPFS pinning at: nft.storage
# Used for HTS NFT metadata (HIP-412 compliant)

NFT_STORAGE_API_KEY=your_nft_storage_key

# ■■ Mirror Node ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Free REST API — no API key needed
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# ■■ App Config ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
