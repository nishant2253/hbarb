# ================================================================
# TradeAgent — Frontend Environment Variables
# Copy this file to .env.local and fill in your real values.
# ================================================================

# ■■ Backend API ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
NEXT_PUBLIC_API_URL=http://localhost:3001

# ■■ Supabase (public keys — safe to expose) ■■■■■■■■■■■■■■■
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ■■ WalletConnect — for HashPack integration ■■■■■■■■■■■■■■■
# Get a free project ID at: cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# ■■ Hedera Network ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
NEXT_PUBLIC_HASHSCAN_BASE_URL=https://hashscan.io/testnet
